<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/svRegister"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_gold_screen"
    android:fillViewport="true"
    tools:context=".auth.RegistrationActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="28dp"
        android:paddingEnd="22dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/auth_gold_yellow"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/auth_topbar_register"
            android:textColor="@color/auth_gold_text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_auth_gold_card"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_register_title_simple"
                android:textColor="@color/auth_gold_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/auth_field_full_name"
                android:textColor="@color/auth_gold_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tieFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_auth_gold_field"
                android:hint="@string/auth_field_full_name"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp"
                android:textColor="@color/auth_gold_text_primary"
                android:textColorHint="@color/auth_gold_text_secondary"
                tools:text="John Stem" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/email"
                android:textColor="@color/auth_gold_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tieEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_auth_gold_field"
                android:hint="@string/email_hint"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp"
                android:textColor="@color/auth_gold_text_primary"
                android:textColorHint="@color/auth_gold_text_secondary"
                tools:text="john@email.com" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/Password"
                android:textColor="@color/auth_gold_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tiePassword1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_auth_gold_field"
                android:hint="@string/Password_hint"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp"
                android:textColor="@color/auth_gold_text_primary"
                android:textColorHint="@color/auth_gold_text_secondary"
                tools:text="******" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/Re_Password"
                android:textColor="@color/auth_gold_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tiePassword2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_auth_gold_field"
                android:hint="@string/Re_Password"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp"
                android:textColor="@color/auth_gold_text_primary"
                android:textColorHint="@color/auth_gold_text_secondary"
                tools:text="******" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_auth_gold_section"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/Gender"
                    android:textColor="@color/auth_gold_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbMale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/auth_gold_yellow"
                        android:text="@string/auth_gender_male"
                        android:textColor="@color/auth_gold_text_primary" />

                    <RadioButton
                        android:id="@+id/rbFemale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/auth_gold_yellow"
                        android:text="@string/auth_gender_female"
                        android:textColor="@color/auth_gold_text_primary" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_auth_gold_section"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_register_body_section"
                    android:textColor="@color/auth_gold_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sldValAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Age: 30"
                    android:textColor="@color/auth_gold_text_primary"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sldAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/Age"
                    android:stepSize="1"
                    android:value="30"
                    android:valueFrom="10"
                    android:valueTo="100"
                    app:haloColor="@color/auth_gold_ripple"
                    app:thumbColor="@color/auth_gold_yellow"
                    app:tickVisible="false"
                    app:trackColorActive="@color/auth_gold_yellow"
                    app:trackColorInactive="@color/auth_gold_stroke" />

                <TextView
                    android:id="@+id/sldValWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Weight(kg): 70"
                    android:textColor="@color/auth_gold_text_primary"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sldWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/Weight"
                    android:stepSize="1"
                    android:value="70"
                    android:valueFrom="30"
                    android:valueTo="200"
                    app:haloColor="@color/auth_gold_ripple"
                    app:thumbColor="@color/auth_gold_yellow"
                    app:tickVisible="false"
                    app:trackColorActive="@color/auth_gold_yellow"
                    app:trackColorInactive="@color/auth_gold_stroke" />

                <TextView
                    android:id="@+id/sldValHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Height(cm): 100"
                    android:textColor="@color/auth_gold_text_primary"
                    android:textStyle="bold" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sldHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/Height"
                    android:stepSize="1"
                    android:value="100"
                    android:valueFrom="50"
                    android:valueTo="300"
                    app:haloColor="@color/auth_gold_ripple"
                    app:thumbColor="@color/auth_gold_yellow"
                    app:tickVisible="false"
                    app:trackColorActive="@color/auth_gold_yellow"
                    app:trackColorInactive="@color/auth_gold_stroke" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                style="@style/Widget.FitNova.Button.AuthGold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:minHeight="54dp"
                android:text="@string/auth_register_button" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
