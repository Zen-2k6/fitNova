<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_dark_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".WorkoutTrackerActivity">

    <TextView
        android:id="@+id/tvWorkoutTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        tools:text="Running" />

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="00:00"
        android:textColor="@color/fitness_primary_soft"
        android:textSize="72sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggleWorkout"
        android:layout_width="240dp"
        android:layout_height="64dp"
        android:layout_marginTop="64dp"
        android:text="Start"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/auth_button_blue"
        app:cornerRadius="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFinishWorkout"
        android:layout_width="240dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:text="Finish"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#FF5252"
        app:cornerRadius="32dp" />
</LinearLayout>
