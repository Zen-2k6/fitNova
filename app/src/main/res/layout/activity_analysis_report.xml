<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auth_dark_background"
    android:fillViewport="true"
    tools:context=".analysis.AnalysisReportActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingTop="18dp"
            android:paddingEnd="24dp"
            android:paddingBottom="12dp">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@color/auth_logo_chip">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/fitness_logo" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analysis_report_title"
                    android:textColor="@color/auth_gold_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/analysis_report_subtitle"
                    android:textColor="@color/auth_gold_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackAnalysis"
                style="@style/Widget.FitNova.Button.NeonSoft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="40dp"
                android:text="@string/profile_cancel_button"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAnalysisLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:text="@string/analysis_report_loading"
            android:textColor="@color/auth_gold_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAnalysisEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:text="@string/analysis_report_empty"
            android:textColor="@color/auth_gold_text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAnalysisFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/auth_gold_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analysis_report_filters_title"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAnalysisActivityRunning"
                            style="@style/Widget.FitNova.Button.NeonSoft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minHeight="42dp"
                            android:text="@string/fitness_activity_running" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAnalysisActivityWalking"
                            style="@style/Widget.FitNova.Button.NeonSoft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:minHeight="42dp"
                            android:text="@string/fitness_activity_walking" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAnalysisActivityWeight"
                            style="@style/Widget.FitNova.Button.NeonSoft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:minHeight="42dp"
                            android:text="@string/fitness_activity_weight" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAnalysisActivityCycling"
                            style="@style/Widget.FitNova.Button.NeonSoft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:minHeight="42dp"
                            android:text="@string/fitness_activity_cycling" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAnalysisOverview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/auth_gold_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvAnalysisOverviewTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Running Overview" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/fitness_primary_soft"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvAnalysisStatOneLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/fitness_text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="Top Distance" />

                        <TextView
                            android:id="@+id/tvAnalysisStatOneValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/fitness_text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="8.4 km" />
                    </LinearLayout>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/fitness_warm_soft"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvAnalysisStatTwoLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/fitness_text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="Longest Time" />

                        <TextView
                            android:id="@+id/tvAnalysisStatTwoValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/fitness_text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="01:02:14" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/fitness_warm_soft"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvAnalysisStatThreeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/fitness_text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="Top Calories" />

                        <TextView
                            android:id="@+id/tvAnalysisStatThreeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/fitness_text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="640 kcal" />
                    </LinearLayout>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/fitness_primary_soft"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvAnalysisStatFourLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/fitness_text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="Top Speed" />

                        <TextView
                            android:id="@+id/tvAnalysisStatFourValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/fitness_text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="13.8 km/h" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAnalysisTrends"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/auth_gold_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analysis_report_trends_title"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnalysisPeriodWeek"
                        style="@style/Widget.FitNova.Button.NeonSoft"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="42dp"
                        android:text="@string/analysis_report_period_week" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnalysisPeriodMonth"
                        style="@style/Widget.FitNova.Button.NeonSoft"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="42dp"
                        android:text="@string/analysis_report_period_month" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/analysis_report_metric_label"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/auth_button_blue"
                    app:endIconMode="dropdown_menu"
                    app:hintTextColor="@color/auth_button_blue">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdownAnalysisMetric"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:maxLines="1"
                        android:textColor="@color/fitness_text_primary"
                        android:textColorHint="@color/auth_hint"
                        tools:text="Distance" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnalysisPreviousPeriod"
                        style="@style/Widget.FitNova.Button.NeonSoft"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:padding="0dp"
                        app:icon="@drawable/ic_chevron_left"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="20dp"
                        app:iconTint="@color/auth_gold_yellow" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_auth_gold_field"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/analysis_report_trends_title"
                            android:textColor="@color/fitness_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAnalysisSelectedPeriod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:textColor="@color/fitness_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="31 Mar - 06 Apr" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnalysisNextPeriod"
                        style="@style/Widget.FitNova.Button.NeonSoft"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:minWidth="44dp"
                        android:minHeight="44dp"
                        android:padding="0dp"
                        app:icon="@drawable/ic_chevron_right"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="20dp"
                        app:iconTint="@color/auth_gold_yellow" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAnalysisChartTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Running Distance Trend" />

                <TextView
                    android:id="@+id/tvAnalysisTrendEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/analysis_report_weekly_trend_empty"
                    android:textColor="@color/auth_hint"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:id="@+id/scrollAnalysisTrendChart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fillViewport="true"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/llAnalysisTrendChart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="bottom"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAnalysisBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/auth_gold_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analysis_report_body_title"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAnalysisBmiValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="15sp"
                    tools:text="BMI: 24.4 (Healthy range)" />

                <TextView
                    android:id="@+id/tvAnalysisWaterGoalValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="15sp"
                    tools:text="Water Goal: 2.6 L / day" />

                <TextView
                    android:id="@+id/tvAnalysisHealthyRangeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="15sp"
                    tools:text="Healthy Range: 57.3 - 77.2 kg" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAnalysisSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/auth_gold_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analysis_report_summary_title"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAnalysisSummaryBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/fitness_text_primary"
                    android:textSize="15sp"
                    tools:text="Running has 12 saved sessions. Best distance is 8.4 km, longest time is 01:02:14, top calories burned is 640 kcal, and best average speed is 13.8 km/h." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
