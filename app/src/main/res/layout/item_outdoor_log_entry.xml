<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@color/fitness_primary_soft"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvOutdoorLogEntryDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/fitness_text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="2026-04-01 15:20:00" />

    <TextView
        android:id="@+id/tvOutdoorLogEntryPrimary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/fitness_text_primary"
        android:textSize="13sp"
        tools:text="Time: 00:24 • Distance: 3.20 km" />

    <TextView
        android:id="@+id/tvOutdoorLogEntrySecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/fitness_text_secondary"
        android:textSize="12sp"
        tools:text="Calories: 210 kcal • Reached destination" />
</LinearLayout>
