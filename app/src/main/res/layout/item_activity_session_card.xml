<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/auth_gold_surface"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="136dp"
        android:orientation="horizontal"
        android:padding="14dp">

        <FrameLayout
            android:layout_width="104dp"
            android:layout_height="108dp">

            <ImageView
                android:id="@+id/imgSessionActivity"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@drawable/fitness" />

            <View
                android:id="@+id/viewSessionImageOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.08"
                android:background="@color/dashboard_activity_running" />
        </FrameLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="96dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:background="@color/dashboard_line" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSessionActivityName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/fitness_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Running" />

            <TextView
                android:id="@+id/tvSessionActivityDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/fitness_text_secondary"
                android:textSize="13sp"
                tools:text="Track route, distance, and calorie burn for your outdoor runs." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartSessionActivity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:minHeight="42dp"
                android:text="@string/fitness_activity_start"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
