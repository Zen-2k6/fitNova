<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="@color/auth_neon_field_fill" />
            <stroke
                android:width="2dp"
                android:color="@color/neon_blue_glow" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="@color/auth_neon_field_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/auth_neon_field_stroke" />
        </shape>
    </item>
</selector>
