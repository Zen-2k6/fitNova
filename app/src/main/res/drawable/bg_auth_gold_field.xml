<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/auth_gold_field_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/auth_gold_yellow" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/auth_gold_field_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/auth_gold_stroke" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
